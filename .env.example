# Vercel Postgres (automatically injected when Postgres DB is linked)
# Or set these manually for external Neon/Postgres:
POSTGRES_URL=your_postgres_connection_string
POSTGRES_PRISMA_URL=your_postgres_connection_string
POSTGRES_URL_NO_SSL=your_postgres_connection_string
POSTGRES_URL_NON_POOLING=your_postgres_connection_string
POSTGRES_USER=your_user
POSTGRES_HOST=your_host
POSTGRES_PASSWORD=your_password
POSTGRES_DATABASE=your_database

# OneSignal (optional - for push notifications)
ONESIGNAL_APP_ID=f426ca4c-6613-4a39-988b-ddb6dcf34304
ONESIGNAL_REST_KEY=your_onesignal_rest_api_key
